# AWS deployment (local deploy:aws and GitHub Actions secrets)
S3_BUCKET_NAME=blog.fazezero.com
CLOUDFRONT_DISTRIBUTION_ID=your-cloudfront-distribution-id
AWS_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/your-github-actions-role
AWS_REGION=us-east-1

# Site URL used at build time for canonical URLs, sitemap, and RSS
PUBLIC_SITE_URL=https://blog.fazezero.com

---
import { siteName, socialLinks } from '@/data/site';

const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-brand-border" style="background: var(--footer-bg);">
  <div class="container-page py-12">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-md space-y-4">
        <p class="site-logo text-brand-ink" style="color: var(--footer-text);">
          faze<span class="site-logo-accent">ZERO</span>
        </p>
        <p class="text-sm leading-relaxed" style="color: var(--footer-muted);">
          Institutional insights on stablecoin payments, tokenization, compliance, and digital finance.
        </p>
      </div>

      <div class="space-y-3">
        <p class="text-sm font-semibold" style="color: var(--footer-text);">Connect</p>
        <ul class="space-y-2">
          {
            socialLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  class="text-sm transition-colors hover:text-brand-primary"
                  style="color: var(--footer-muted);"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t pt-6" style="border-color: rgba(255, 255, 255, 0.1);">
      <p class="text-sm" style="color: var(--footer-muted);">
        &copy; {year} {siteName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>

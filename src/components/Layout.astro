---
import '@/styles/global.css';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import SEO from '@/components/SEO.astro';
import { siteUrl } from '@/data/site';
import type { SeoInput } from '@/lib/seo';

interface Props extends SeoInput {
  class?: string;
  rss?: boolean;
}

const { class: className, rss: showRss = true, ...seoProps } = Astro.props;
const rssUrl = new URL('/rss.xml', siteUrl).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Overpass:ital,wght@0,300..800;1,300..800&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored ?? (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
    <SEO {...seoProps} />
    {showRss && <link rel="alternate" type="application/rss+xml" title="FazeZero Blog RSS" href={rssUrl} />}
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class:list={['flex-1', className]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>

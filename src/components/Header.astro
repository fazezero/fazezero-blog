---
import ThemeToggle from '@/components/ThemeToggle.astro';
import { archive, blog, search } from '@/lib/routes';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const navItems = [{ label: 'Archive', href: archive() }];

function isBlogActive(): boolean {
  return (
    currentPath === '/blog' ||
    (currentPath.startsWith('/blog/') &&
      !currentPath.startsWith('/blog/archive') &&
      !currentPath.startsWith('/blog/tags') &&
      !currentPath.startsWith('/blog/series'))
  );
}

function isActive(href: string): boolean {
  const normalized = href.replace(/\/$/, '') || '/';
  return currentPath === normalized || currentPath.startsWith(`${normalized}/`);
}
---

<header
  class="sticky top-0 z-50 border-b border-brand-border backdrop-blur-md"
  style="background: var(--header-bg);"
>
  <div class="container-page flex items-center justify-between py-4">
    <a href={blog()} class:list={['site-logo', isBlogActive() && 'text-brand-primary']}>
      faze<span class="site-logo-accent">ZERO</span>
      <span class="ml-2 text-sm font-normal text-brand-muted">Blog</span>
    </a>

    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-4 lg:flex" aria-label="Main navigation">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={['nav-link', isActive(item.href) && 'nav-link-active font-medium']}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <a
        href={search()}
        class:list={['theme-toggle', isActive(search()) && 'border-brand-primary text-brand-primary']}
        aria-label="Search"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
          />
        </svg>
      </a>

      <ThemeToggle />

      <button
        type="button"
        id="mobile-menu-button"
        class="theme-toggle lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Toggle navigation menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-brand-border lg:hidden"
    style="background: var(--header-bg);"
    aria-label="Mobile navigation"
  >
    <div class="container-page flex flex-col gap-1 py-3">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm transition-colors',
              isActive(item.href)
                ? 'bg-brand-elevated font-medium text-brand-primary'
                : 'text-brand-muted hover:bg-brand-elevated hover:text-brand-ink',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');

  if (button && menu) {
    button.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden', isOpen);
      button.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>

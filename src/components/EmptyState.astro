---
interface Props {
  title: string;
  message: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { title, message, ctaLabel, ctaHref } = Astro.props;
---

<div class="rounded-xl border border-dashed border-brand-border bg-brand-elevated px-8 py-16 text-center">
  <h2 class="text-xl font-semibold text-brand-ink">{title}</h2>
  <p class="mx-auto mt-4 max-w-lg text-sm leading-relaxed text-brand-muted">
    {message}
  </p>
  {
    ctaLabel && ctaHref && (
      <a href={ctaHref} class="btn-secondary mt-8">
        {ctaLabel}
      </a>
    )
  }
</div>

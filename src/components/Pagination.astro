---
interface Props {
  currentPage: number;
  totalPages: number;
  getPagePath: (page: number) => string;
}

const { currentPage, totalPages, getPagePath } = Astro.props;
---

{
  totalPages > 1 && (
    <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Pagination">
      {
        currentPage > 1 && (
          <a href={getPagePath(currentPage - 1)} class="btn-secondary px-3 py-1.5">
            Previous
          </a>
        )
      }

      {
        Array.from({ length: totalPages }, (_, index) => {
          const page = index + 1;
          const isCurrent = page === currentPage;

          return (
            <a
              href={getPagePath(page)}
              class:list={['badge px-3 py-1.5', isCurrent && 'badge-active']}
              aria-current={isCurrent ? 'page' : undefined}
            >
              {page}
            </a>
          );
        })
      }

      {
        currentPage < totalPages && (
          <a href={getPagePath(currentPage + 1)} class="btn-secondary px-3 py-1.5">
            Next
          </a>
        )
      }
    </nav>
  )
}

---
import ArticleCard from '@/components/ArticleCard.astro';
import EmptyState from '@/components/EmptyState.astro';
import Pagination from '@/components/Pagination.astro';
import type { ArticleEntry } from '@/lib/content';
import { paginate, getTotalPages } from '@/lib/content';

interface Props {
  allArticles: ArticleEntry[];
  currentPage: number;
  emptyTitle: string;
  emptyMessage: string;
  emptyCtaLabel?: string;
  emptyCtaHref?: string;
  getPagePath: (page: number) => string;
}

const {
  allArticles,
  currentPage,
  emptyTitle,
  emptyMessage,
  emptyCtaLabel,
  emptyCtaHref,
  getPagePath,
} = Astro.props;

const articles = paginate(allArticles, currentPage);
const totalPages = getTotalPages(allArticles.length);
---

{
  allArticles.length === 0 ? (
    <EmptyState
      title={emptyTitle}
      message={emptyMessage}
      ctaLabel={emptyCtaLabel}
      ctaHref={emptyCtaHref}
    />
  ) : (
    <>
      <div class="grid gap-6 md:grid-cols-2">
        {articles.map((entry) => (
          <ArticleCard entry={entry} />
        ))}
      </div>
      <Pagination
        currentPage={currentPage}
        totalPages={totalPages}
        getPagePath={getPagePath}
      />
    </>
  )
}

---
import { resolveSeo, type SeoInput } from '@/lib/seo';

interface Props extends SeoInput {}

const seo = resolveSeo(Astro.props);
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />
{seo.paginationPrev && <link rel="prev" href={seo.paginationPrev} />}
{seo.paginationNext && <link rel="next" href={seo.paginationNext} />}
{seo.noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:type" content={seo.ogType} />
<meta property="og:site_name" content={seo.ogSiteName} />
<meta property="og:locale" content="en_US" />
<meta property="og:title" content={seo.ogTitle} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:image" content={seo.ogImage} />

{
  seo.ogType === 'article' && seo.articlePublishedTime && (
    <meta property="article:published_time" content={seo.articlePublishedTime} />
  )
}
{
  seo.ogType === 'article' && seo.articleModifiedTime && (
    <meta property="article:modified_time" content={seo.articleModifiedTime} />
  )
}
{
  seo.ogType === 'article' && seo.articleAuthor && (
    <meta property="article:author" content={seo.articleAuthor} />
  )
}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={seo.twitterSite} />
<meta name="twitter:title" content={seo.ogTitle} />
<meta name="twitter:description" content={seo.ogDescription} />
<meta name="twitter:image" content={seo.ogImage} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

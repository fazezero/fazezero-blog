---
import { getAllCategories } from '@/data/categories';
import { blog, category as categoryRoute } from '@/lib/routes';

interface Props {
  activeCategory?: string;
}

const { activeCategory } = Astro.props;
const categories = getAllCategories();
---

<nav class="flex flex-wrap gap-2" aria-label="Blog categories">
  <a
    href={blog()}
    class:list={[
      'rounded-full border px-3 py-1.5 text-sm transition-colors',
      !activeCategory
        ? 'border-brand-navy bg-brand-navy text-white'
        : 'border-brand-border text-brand-muted hover:border-brand-slate hover:text-brand-navy',
    ]}
  >
    All
  </a>
  {
    categories.map((item) => (
      <a
        href={categoryRoute(item.slug)}
        class:list={[
          'rounded-full border px-3 py-1.5 text-sm transition-colors',
          activeCategory === item.slug
            ? 'border-brand-navy bg-brand-navy text-white'
            : 'border-brand-border text-brand-muted hover:border-brand-slate hover:text-brand-navy',
        ]}
      >
        {item.title}
      </a>
    ))
  }
</nav>

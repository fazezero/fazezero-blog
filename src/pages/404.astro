---
import Layout from '@/components/Layout.astro';
import { home } from '@/lib/routes';
---

<Layout title="Page not found" noindex={true}>
  <section class="container-page py-20 lg:py-28">
    <div class="mx-auto max-w-xl space-y-6 text-center">
      <p class="eyebrow">404</p>
      <h1 class="text-3xl font-bold tracking-tight text-brand-ink md:text-4xl">
        Page not found
      </h1>
      <p class="text-base leading-relaxed text-brand-slate">
        The page you are looking for does not exist or may have been moved.
      </p>
      <a href={home()} class="btn-primary">
        Return home
      </a>
    </div>
  </section>
</Layout>

---
import Layout from '@/components/Layout.astro';
import { home } from '@/lib/routes';
---

<Layout title="Page not found" noindex={true}>
  <section class="container-page py-20 lg:py-28">
    <div class="mx-auto max-w-xl space-y-6 text-center">
      <p class="text-sm font-medium uppercase tracking-widest text-brand-muted">404</p>
      <h1 class="text-3xl font-semibold tracking-tight text-brand-navy md:text-4xl">
        Page not found
      </h1>
      <p class="text-base leading-relaxed text-brand-muted">
        The page you are looking for does not exist or may have been moved.
      </p>
      <a
        href={home()}
        class="inline-flex items-center rounded-md border border-brand-navy bg-brand-navy px-5 py-2.5 text-sm font-medium text-white hover:bg-brand-slate"
      >
        Return home
      </a>
    </div>
  </section>
</Layout>

---
import ArticleList from '@/components/ArticleList.astro';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { getAllCategories } from '@/data/categories';
import { getArticlesByCategory, getTotalPages } from '@/lib/content';
import { category as categoryRoute } from '@/lib/routes';

export async function getStaticPaths() {
  const categories = getAllCategories();
  const paths: Array<{ params: { category: string; page: string }; props: { category: typeof categories[0]; currentPage: number } }> = [];

  for (const category of categories) {
    const articles = await getArticlesByCategory(category.slug);
    const totalPages = getTotalPages(articles.length);

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: { category: category.slug, page: String(page) },
        props: { category, currentPage: page },
      });
    }
  }

  return paths;
}

const { category, currentPage } = Astro.props;
const articles = await getArticlesByCategory(category.slug);
const totalPages = getTotalPages(articles.length);
const getPagePath = (page: number) => categoryRoute(category.slug, page);
---

<BlogLayout
  title={`${category.title} — Page ${currentPage}`}
  description={category.description}
  activeCategory={category.slug}
  canonicalPath={categoryRoute(category.slug, currentPage)}
  pagination={{ currentPage, totalPages, getPagePath }}
>
  <ArticleList
    allArticles={articles}
    currentPage={currentPage}
    emptyTitle={`No articles in ${category.title}`}
    emptyMessage="Articles in this category will appear here once MDX content is published."
    getPagePath={getPagePath}
  />
</BlogLayout>

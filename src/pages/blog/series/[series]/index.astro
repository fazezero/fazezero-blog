---
import ArticleList from '@/components/ArticleList.astro';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { formatSeriesLabel, getAllSeries, getArticlesBySeries, getTotalPages } from '@/lib/content';
import { blog, series as seriesRoute, seriesDetail } from '@/lib/routes';

export async function getStaticPaths() {
  const allSeries = await getAllSeries();

  return allSeries.map((seriesSlug) => ({
    params: { series: seriesSlug },
    props: { seriesSlug, currentPage: 1 },
  }));
}

const { seriesSlug, currentPage } = Astro.props;
const articles = await getArticlesBySeries(seriesSlug);
const seriesLabel = formatSeriesLabel(seriesSlug);
const totalPages = getTotalPages(articles.length);
const getPagePath = (page: number) => seriesDetail(seriesSlug, page);
---

<BlogLayout
  title={`Series: ${seriesLabel}`}
  description={`Articles in the ${seriesLabel} series.`}
  canonicalPath={seriesDetail(seriesSlug)}
  pagination={{ currentPage, totalPages, getPagePath }}
>
  <ArticleList
    allArticles={articles}
    currentPage={currentPage}
    emptyTitle={`No articles in "${seriesLabel}"`}
    emptyMessage="Articles in this series will appear here once MDX content with matching series metadata is published."
    emptyCtaLabel="Browse all series"
    emptyCtaHref={seriesRoute()}
    getPagePath={getPagePath}
  />
</BlogLayout>

---
import Layout from '@/components/Layout.astro';
import { resolveCanonical } from '@/lib/seo';
import { search } from '@/lib/routes';
---

<Layout
  title="Search"
  description="Search the FazeZero blog."
  canonical={resolveCanonical(search())}
>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />

  <section class="container-page py-16 lg:py-20">
    <div class="mx-auto max-w-2xl space-y-8">
      <header class="space-y-4 text-center">
        <h1 class="text-3xl font-bold tracking-tight text-brand-ink md:text-4xl">Search</h1>
        <p class="text-base leading-relaxed text-brand-slate">
          Search articles across the FazeZero blog.
        </p>
      </header>

      <div id="search" class="pagefind-search mx-auto w-full"></div>
    </div>
  </section>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    function initPagefind() {
      if (typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search',
          showImages: false,
        });
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPagefind);
    } else {
      initPagefind();
    }
  </script>

  <style is:global>
    .pagefind-search {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: var(--color-accent-primary);
      --pagefind-ui-text: var(--color-text-secondary);
      --pagefind-ui-background: var(--color-bg-secondary);
      --pagefind-ui-border: var(--color-border);
      --pagefind-ui-tag: var(--color-bg-tertiary);
      --pagefind-ui-font: Overpass, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
    }

    .pagefind-search .pagefind-ui__search-input {
      border-radius: 0.5rem;
      border: 1px solid var(--color-border);
      padding: 0.75rem 1rem;
      font-size: 0.875rem;
      background: var(--color-bg-secondary);
      color: var(--color-text-primary);
    }

    .pagefind-search .pagefind-ui__result {
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }

    .pagefind-search .pagefind-ui__result-title {
      font-weight: 600;
      color: var(--color-text-primary);
    }
  </style>
</Layout>

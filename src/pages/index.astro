---
import Layout from '@/components/Layout.astro';
import { categories } from '@/data/categories';
import { siteDescription, siteName } from '@/data/site';
import { blog, category } from '@/lib/routes';
import { resolveCanonical } from '@/lib/seo';
---

<Layout
  title={`${siteName} | Institutional Digital Finance Insights`}
  description={siteDescription}
  canonical={resolveCanonical('/')}
>
  <section class="relative overflow-hidden py-20 lg:py-28">
    <div
      class="pointer-events-none absolute inset-0 opacity-60"
      aria-hidden="true"
      style="background: radial-gradient(circle at 20% 20%, rgba(120, 64, 240, 0.12), transparent 50%), radial-gradient(circle at 80% 60%, rgba(61, 229, 255, 0.08), transparent 40%);"
    ></div>

    <div class="container-page relative">
      <div class="mx-auto max-w-3xl space-y-8">
        <p class="eyebrow">Institutional Digital Finance</p>
        <h1 class="text-4xl font-bold tracking-tight text-brand-ink md:text-5xl lg:text-6xl">
          Insights on <span class="gradient-text">stablecoins</span>, tokenization, and compliance
        </h1>
        <p class="text-lg leading-relaxed text-brand-slate">
          {siteDescription}
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={blog()} class="btn-primary">View the blog</a>
          <a
            href="https://fazezero.com/platform"
            class="btn-secondary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Explore the platform
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-brand-border py-16">
    <div class="container-page">
      <div class="mb-10 max-w-2xl">
        <h2 class="text-2xl font-bold text-brand-ink">Built for institutional readers</h2>
        <p class="mt-3 leading-relaxed text-brand-slate">
          The FazeZero blog covers stablecoin payments, tokenization, compliance, implementation,
          and market developments with a focus on clarity, rigor, and practical guidance for
          financial institutions and enterprise teams.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          categories.map((item) => (
            <a href={category(item.slug)} class="card-interactive group">
              <h3 class="font-semibold text-brand-ink group-hover:text-brand-primary">{item.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-brand-muted">{item.description}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
